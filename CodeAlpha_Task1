<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Creative Image Gallery</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      background:linear-gradient(135deg,#0f172a,#1e293b);
      min-height:100vh;
      padding:40px;
      color:white;
    }

    .title{
      text-align:center;
      margin-bottom:35px;
    }

    .title h1{
      font-size:50px;
      margin-bottom:10px;
      letter-spacing:2px;
    }

    .title p{
      color:#cbd5e1;
      font-size:18px;
    }

    /* FILTER BUTTONS */

    .buttons{
      display:flex;
      justify-content:center;
      flex-wrap:wrap;
      gap:15px;
      margin-bottom:40px;
    }

    .buttons button{
      padding:12px 28px;
      border:none;
      border-radius:30px;
      background:white;
      color:#0f172a;
      font-size:15px;
      font-weight:bold;
      cursor:pointer;
      transition:0.3s;
    }

    .buttons button:hover{
      background:#38bdf8;
      color:white;
      transform:translateY(-3px);
    }

    /* GALLERY */

    .gallery{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
      gap:25px;
    }

    .card{
      position:relative;
      overflow:hidden;
      border-radius:20px;
      cursor:pointer;
      transition:0.4s;
      box-shadow:0 10px 25px rgba(0,0,0,0.3);
    }

    .card img{
      width:100%;
      height:320px;
      object-fit:cover;
      display:block;
      transition:0.5s;
    }

    .card:hover img{
      transform:scale(1.1);
      filter:brightness(60%);
    }

    .overlay{
      position:absolute;
      bottom:-100%;
      left:0;
      width:100%;
      padding:20px;
      background:rgba(0,0,0,0.7);
      transition:0.4s;
    }

    .card:hover .overlay{
      bottom:0;
    }

    .overlay h2{
      margin-bottom:8px;
      font-size:24px;
    }

    .overlay p{
      color:#ddd;
      font-size:14px;
    }

    /* LIGHTBOX */

    .lightbox{
      position:fixed;
      top:0;
      left:0;
      width:100%;
      height:100%;
      background:rgba(0,0,0,0.95);
      display:none;
      justify-content:center;
      align-items:center;
      z-index:1000;
      flex-direction:column;
    }

    .lightbox img{
      width:80%;
      max-width:850px;
      border-radius:15px;
      animation:zoom 0.4s ease;
    }

    @keyframes zoom{

      from{
        transform:scale(0.5);
        opacity:0;
      }

      to{
        transform:scale(1);
        opacity:1;
      }

    }

    .close{
      position:absolute;
      top:20px;
      right:35px;
      font-size:45px;
      color:white;
      cursor:pointer;
    }

    .nav-btn{
      position:absolute;
      top:50%;
      transform:translateY(-50%);
      background:white;
      color:black;
      border:none;
      padding:14px 18px;
      border-radius:50%;
      font-size:22px;
      cursor:pointer;
      transition:0.3s;
    }

    .nav-btn:hover{
      background:#38bdf8;
      color:white;
    }

    .prev{
      left:40px;
    }

    .next{
      right:40px;
    }

    /* RESPONSIVE */

    @media(max-width:768px){

      body{
        padding:20px;
      }

      .title h1{
        font-size:34px;
      }

      .gallery{
        grid-template-columns:1fr;
      }

      .lightbox img{
        width:95%;
      }

      .nav-btn{
        padding:10px 14px;
      }

    }

  </style>

</head>
<body>

  <!-- TITLE -->

  <div class="title">

    <h1>Creative Image Gallery</h1>

    <p>Interactive Frontend Gallery using HTML CSS JavaScript</p>

  </div>

  <!-- FILTER BUTTONS -->

  <div class="buttons">

    <button onclick="filterImages('all')">All</button>

    <button onclick="filterImages('nature')">Nature</button>

    <button onclick="filterImages('city')">City</button>

    <button onclick="filterImages('travel')">Travel</button>

  </div>

  <!-- GALLERY -->

  <div class="gallery">

    <!-- NATURE -->

    <div class="card nature">

      <img src="https://picsum.photos/id/1018/600/800" alt="">

      <div class="overlay">

        <h2>Forest Nature</h2>

        <p>Beautiful green landscape view</p>

      </div>

    </div>

    <!-- CITY -->

    <div class="card city">

      <img src="https://picsum.photos/id/1011/600/800" alt="">

      <div class="overlay">

        <h2>Modern City</h2>

        <p>Night lights and urban buildings</p>

      </div>

    </div>

    <!-- TRAVEL -->

    <div class="card travel">

      <img src="https://picsum.photos/id/1015/600/800" alt="">

      <div class="overlay">

        <h2>Beach Travel</h2>

        <p>Relaxing vacation destination</p>

      </div>

    </div>

    <!-- NATURE -->

    <div class="card nature">

      <img src="https://picsum.photos/id/1039/600/800" alt="">

      <div class="overlay">

        <h2>Mountain Lake</h2>

        <p>Peaceful water reflection</p>

      </div>

    </div>

    <!-- CITY -->

    <div class="card city">

      <img src="https://picsum.photos/id/1043/600/800" alt="">

      <div class="overlay">

        <h2>Urban Streets</h2>

        <p>Beautiful architecture photography</p>

      </div>

    </div>

    <!-- TRAVEL -->

    <div class="card travel">

      <img src="https://picsum.photos/id/1040/600/800" alt="">

      <div class="overlay">

        <h2>Adventure Road</h2>

        <p>Creative travel photography collection</p>

      </div>

    </div>

  </div>

  <!-- LIGHTBOX -->

  <div class="lightbox" id="lightbox">

    <span class="close">&times;</span>

    <button class="nav-btn prev">&#10094;</button>

    <img id="lightbox-img">

    <button class="nav-btn next">&#10095;</button>

  </div>

  <script>

    const cards = document.querySelectorAll(".card");

    const images = document.querySelectorAll(".card img");

    const lightbox = document.getElementById("lightbox");

    const lightboxImg = document.getElementById("lightbox-img");

    const closeBtn = document.querySelector(".close");

    const nextBtn = document.querySelector(".next");

    const prevBtn = document.querySelector(".prev");

    let current = 0;

    /* OPEN LIGHTBOX */

    images.forEach((img,index)=>{

      img.addEventListener("click",()=>{

        lightbox.style.display = "flex";

        lightboxImg.src = img.src;

        current = index;

      });

    });

    /* CLOSE LIGHTBOX */

    closeBtn.addEventListener("click",()=>{

      lightbox.style.display = "none";

    });

    /* NEXT BUTTON */

    nextBtn.addEventListener("click",()=>{

      current++;

      if(current >= images.length){

        current = 0;

      }

      lightboxImg.src = images[current].src;

    });

    /* PREVIOUS BUTTON */

    prevBtn.addEventListener("click",()=>{

      current--;

      if(current < 0){

        current = images.length - 1;

      }

      lightboxImg.src = images[current].src;

    });

    /* FILTER FUNCTION */

    function filterImages(category){

      cards.forEach((card)=>{

        if(category === "all"){

          card.style.display = "block";

        }

        else{

          if(card.classList.contains(category)){

            card.style.display = "block";

          }

          else{

            card.style.display = "none";

          }

        }

      });

    }

  </script>

</body>
</html>
